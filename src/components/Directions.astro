---
import Section from '@components/Section.astro';
import venue from '@config/venue.json';
import travel from '@data/travel.json';
import { localizedHref, t, tField, type Locale } from '@lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const title = t('directions.title', locale);
const venueName = tField(venue.name, locale) ?? '';
const venueHall = tField(venue.hall, locale) ?? '';
const address = tField(venue.address, locale) ?? '';
const subway = tField(venue.transit.subway, locale) ?? '';
const bus = tField(venue.transit.bus, locale) ?? '';
const car = tField(venue.transit.car, locale) ?? '';
const parking = tField(venue.transit.parking, locale) ?? '';

const { lat, lon } = venue;
const venueQuery = encodeURIComponent(venueName);

const kakaoMapUrl = `https://map.kakao.com/link/to/${venueQuery},${lat},${lon}`;
const naverMapUrl = `https://map.naver.com/v5/search/${venueQuery}`;
const googleMapUrl = `https://www.google.com/maps/dir/?api=1&destination=${lat},${lon}`;

// Korean speakers see KakaoMap (familiar to them); everyone else gets Google
// Maps embedded directly so they don't need a Korean app installed.
// Kakao uses the "지도 퍼가기" (roughmap) embed — no SDK key or domain
// registration required. Google uses the official `/maps/embed?pb=...` URL
// from "Share → Embed a map" — that includes the venue's place ID, so the
// pin and label are correct without us composing query params.
const useKakaoEmbed = locale === 'ko';
const kakaoRoughmap = (venue as { kakaoRoughmap?: { timestamp: string; key: string } })
  .kakaoRoughmap;
const googleEmbedSrc =
  (venue as { googleEmbed?: string }).googleEmbed ??
  `https://maps.google.com/maps?q=${lat},${lon}&hl=${locale === 'de' ? 'de' : 'en'}&z=16&output=embed`;

// Kakao's roughmap loader injects `roughmapLander.js` via document.write and
// bundles its own React. Run inline on the main page, that synchronous inject
// runs *during* our React islands' hydration and nulls React's dispatcher,
// crashing the JourneyMap island (React #423). We isolate the whole embed in an
// iframe (srcdoc) so Kakao's document.write + React stay in their own document
// and can never touch the parent page's React.
const kakaoSrcdoc = kakaoRoughmap
  ? `<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><style>html,body{margin:0;padding:0;overflow:hidden;background:transparent}.root_daum_roughmap{width:100%!important;margin:0!important}.root_daum_roughmap .wrap_map{width:100%!important}</style></head><body><div id="daumRoughmapContainer${kakaoRoughmap.timestamp}" class="root_daum_roughmap root_daum_roughmap_landing"></div><script charset="UTF-8" class="daum_roughmap_loader_script" src="https://ssl.daumcdn.net/dmaps/map_js_init/roughmapLoader.js"><\/script><script charset="UTF-8">(function(){var w=Math.max(280,Math.min(640,window.innerWidth||360));var h=Math.round((w*9)/16);new daum.roughmap.Lander({timestamp:"${kakaoRoughmap.timestamp}",key:"${kakaoRoughmap.key}",mapWidth:String(w),mapHeight:String(h)}).render();})();<\/script></body></html>`
  : '';
---

<Section id="directions" title={title}>
  {
    useKakaoEmbed && kakaoRoughmap ? (
      <iframe
        title={`${venueName} on KakaoMap`}
        srcdoc={kakaoSrcdoc}
        loading="lazy"
        class="aspect-[16/9] w-full overflow-hidden rounded-md border border-[var(--color-line)] bg-[var(--color-accent-soft)]"
      />
    ) : (
      <iframe
        title={`${venueName} on Google Maps`}
        src={googleEmbedSrc}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="aspect-[4/3] w-full overflow-hidden rounded-md border border-[var(--color-line)] bg-[var(--color-accent-soft)]"
      />
    )
  }

  <dl class="mt-6 space-y-3 text-sm">
    <div>
      <dt class="text-xs uppercase tracking-[var(--tracking-wedding)] text-[var(--color-muted)]">
        {t('directions.addressLabel', locale)}
      </dt>
      <dd class="mt-1 text-[var(--color-fg)]">{venueName} · {venueHall}</dd>
      <dd class="text-[var(--color-muted)]">{address}</dd>
    </div>
  </dl>

  <div class="mt-6 grid grid-cols-1 gap-2 sm:grid-cols-3">
    <a
      href={kakaoMapUrl}
      target="_blank"
      rel="noopener"
      class="tap-target flex items-center justify-center rounded-md border border-[var(--color-line)] bg-white/60 px-3 py-2.5 text-sm text-[var(--color-fg)] hover:bg-[var(--color-accent-soft)]"
    >
      {t('directions.kakaoButton', locale)}
    </a>
    <a
      href={naverMapUrl}
      target="_blank"
      rel="noopener"
      class="tap-target flex items-center justify-center rounded-md border border-[var(--color-line)] bg-white/60 px-3 py-2.5 text-sm text-[var(--color-fg)] hover:bg-[var(--color-accent-soft)]"
    >
      {t('directions.naverButton', locale)}
    </a>
    <a
      href={googleMapUrl}
      target="_blank"
      rel="noopener"
      class="tap-target flex items-center justify-center rounded-md border border-[var(--color-line)] bg-white/60 px-3 py-2.5 text-sm text-[var(--color-fg)] hover:bg-[var(--color-accent-soft)]"
    >
      {t('directions.googleButton', locale)}
    </a>
  </div>

  <h3 class="mt-10 text-sm font-semibold text-[var(--color-fg)]">
    {t('directions.transitTitle', locale)}
  </h3>
  <ul class="mt-3 space-y-3 text-sm">
    {
      subway && (
        <li class="flex gap-3">
          <span class="w-16 shrink-0 text-[var(--color-muted)]">{t('directions.subwayLabel', locale)}</span>
          <span class="flex-1 text-[var(--color-fg)]">{subway}</span>
        </li>
      )
    }
    {
      bus && (
        <li class="flex gap-3">
          <span class="w-16 shrink-0 text-[var(--color-muted)]">{t('directions.busLabel', locale)}</span>
          <span class="flex-1 text-[var(--color-fg)]">{bus}</span>
        </li>
      )
    }
    {
      car && (
        <li class="flex gap-3">
          <span class="w-16 shrink-0 text-[var(--color-muted)]">{t('directions.carLabel', locale)}</span>
          <span class="flex-1 text-[var(--color-fg)]">{car}</span>
        </li>
      )
    }
    {
      parking && (
        <li class="flex gap-3">
          <span class="w-16 shrink-0 text-[var(--color-muted)]">{t('directions.parkingLabel', locale)}</span>
          <span class="flex-1 text-[var(--color-fg)]">{parking}</span>
        </li>
      )
    }
  </ul>

  <div class="mt-12 flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
    <h3 class="text-sm font-semibold text-[var(--color-fg)]">
      {t('directions.airportTitle', locale)}
    </h3>
    <a
      href={localizedHref('/travel-guide/', locale)}
      class="text-xs text-[var(--color-accent)] hover:underline"
    >
      {t('directions.fullGuideLink', locale)} →
    </a>
  </div>
  <p class="mt-1 text-xs text-[var(--color-muted)]">
    {t('directions.airportIntro', locale)}
  </p>
  <ul class="mt-4 space-y-3">
    {
      travel.fromAirport.map((opt) => (
        <li class="rounded-md border border-[var(--color-line)] bg-white/40 p-4">
          <div class="flex flex-wrap items-center gap-2">
            <h4 class="text-sm font-semibold text-[var(--color-fg)]">
              {tField(opt.title, locale)}
            </h4>
            {opt.recommended && (
              <span class="rounded-full bg-[var(--color-accent)] px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-white">
                {t('directions.recommendedTag', locale)}
              </span>
            )}
          </div>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-fg)]">
            {tField(opt.summary, locale)}
          </p>
          <dl class="mt-3 grid grid-cols-2 gap-x-3 gap-y-2 text-xs sm:grid-cols-3">
            <div>
              <dt class="text-[var(--color-muted)]">{t('directions.fareLabel', locale)}</dt>
              <dd class="text-[var(--color-fg)]">{opt.fare}</dd>
            </div>
            <div>
              <dt class="text-[var(--color-muted)]">{t('directions.durationLabel', locale)}</dt>
              <dd class="text-[var(--color-fg)]">{tField(opt.duration, locale)}</dd>
            </div>
            {opt.boarding && (
              <div class="col-span-2 sm:col-span-1">
                <dt class="text-[var(--color-muted)]">{t('directions.boardingLabel', locale)}</dt>
                <dd class="text-[var(--color-fg)]">{tField(opt.boarding, locale)}</dd>
              </div>
            )}
          </dl>
          {opt.url && (
            <a
              href={opt.url}
              target="_blank"
              rel="noopener"
              class="mt-3 inline-block text-xs text-[var(--color-accent)] hover:underline"
            >
              {t('directions.moreInfo', locale)} ↗
            </a>
          )}
        </li>
      ))
    }
  </ul>

  <h3 class="mt-12 text-sm font-semibold text-[var(--color-fg)]">
    {t('directions.stayTitle', locale)}
  </h3>
  <p class="mt-1 text-xs text-[var(--color-muted)]">
    {t('directions.stayIntro', locale)}
  </p>
  <ul class="mt-4 space-y-3">
    {
      travel.hotels.map((h) => (
        <li class="rounded-md border border-[var(--color-line)] bg-white/40 p-4">
          <div class="flex flex-wrap items-baseline gap-x-2">
            <h4 class="text-sm font-semibold text-[var(--color-fg)]">{h.name}</h4>
            <span class="text-xs text-[var(--color-gold)]" aria-label={`${h.stars} stars`}>
              {'★'.repeat(h.stars)}
            </span>
          </div>
          <p class="text-xs text-[var(--color-muted)]">{h.nameLocal}</p>
          <p class="mt-2 text-sm text-[var(--color-fg)]">{tField(h.distance, locale)}</p>
          <p class="mt-1 text-sm font-medium text-[var(--color-fg)]">
            {h.price}
            <span class="ml-1 text-xs font-normal text-[var(--color-muted)]">
              · {t('directions.priceLabel', locale)}
            </span>
          </p>
          <p class="mt-2 text-xs leading-relaxed text-[var(--color-muted)]">
            {tField(h.note, locale)}
          </p>
          {h.url && (
            <a
              href={h.url}
              target="_blank"
              rel="noopener"
              class="mt-2 inline-block text-xs text-[var(--color-accent)] hover:underline"
            >
              {t('directions.moreInfo', locale)} ↗
            </a>
          )}
        </li>
      ))
    }
  </ul>
</Section>
