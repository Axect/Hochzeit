---
import letters from '@data/letters.encrypted.json';
import { t, type Locale } from '@lib/i18n';
import SecretLetterForm from '@components/SecretLetterForm.tsx';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const title = t('secretLetter.title', locale);
const intro = t('secretLetter.intro', locale);
const trigger = t('secretLetter.discloseTrigger', locale);

const labels = {
  placeholder: t('secretLetter.placeholder', locale),
  submit: t('secretLetter.submit', locale),
  loading: t('secretLetter.loading', locale),
  invalid: t('secretLetter.invalid', locale),
  lockedTitle: t('secretLetter.lockedTitle', locale),
  lockedBody: t('secretLetter.lockedBody', locale),
  missingTranslation: t('secretLetter.missingTranslation', locale),
  letterPrefix: t('secretLetter.letterPrefix', locale),
  close: t('secretLetter.close', locale),
};

const isConfigured = Boolean(letters.configured);
---

<section id="secret-letter" class="px-6 py-12">
  <details class="secret-letter mx-auto max-w-md">
    <summary
      class="tap-target group flex cursor-pointer list-none items-center justify-center gap-3 rounded-full px-4 py-2 text-center text-[11px] uppercase tracking-[0.32em] text-[var(--color-muted)] transition-colors hover:text-[var(--color-accent)]"
    >
      <span aria-hidden="true" class="text-[var(--color-accent)]">❦</span>
      <span>{trigger}</span>
      <span aria-hidden="true" class="text-[10px] transition-transform group-hover:translate-y-[1px]">
        ▾
      </span>
    </summary>

    <div class="mt-8 space-y-4">
      <h3 class="text-center font-serif text-2xl text-[var(--color-fg)]">{title}</h3>
      <p class="mx-auto max-w-sm text-center text-sm text-[var(--color-muted)]">{intro}</p>
      <SecretLetterForm
        client:visible
        locale={locale}
        labels={labels}
        configured={isConfigured}
        pendingCount={(letters as { pendingCount?: number }).pendingCount ?? 0}
        entries={letters.entries ?? {}}
        kdfParams={letters.kdfParams}
      />
    </div>
  </details>
</section>

<style>
  /* Hide the default disclosure triangle so we can render our own ▾ chevron. */
  details.secret-letter > summary::-webkit-details-marker {
    display: none;
  }
  details.secret-letter > summary {
    list-style: none;
  }
  details.secret-letter[open] > summary > span:last-child {
    transform: rotate(180deg);
  }
</style>
