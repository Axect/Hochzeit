---
import { travelGuide } from '@data/travel-guide';
import { localizedHref, type Locale } from '@lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const data = travelGuide;

const homeHref = localizedHref('/', locale);
---

<article class="mx-auto max-w-2xl px-4 pb-20 pt-24 sm:px-6">
  <a
    href={homeHref}
    class="inline-block text-xs text-[var(--color-accent)] hover:underline"
  >
    {data.back[locale]}
  </a>

  <h1 class="mt-6 text-2xl font-semibold leading-tight text-[var(--color-fg)] sm:text-3xl">
    {data.meta.title[locale]}
  </h1>

  <div class="mt-6 space-y-4 text-sm leading-relaxed text-[var(--color-fg)]">
    {data.intro.map((p) => <p>{p[locale]}</p>)}
  </div>

  {
    data.sections.map((section) => (
      <section class="mt-12 border-t border-[var(--color-line)] pt-8">
        <div class="flex flex-wrap items-center gap-2">
          <h2 class="text-lg font-semibold text-[var(--color-fg)] sm:text-xl">
            {section.heading[locale]}
          </h2>
          {section.badge && (
            <span class="rounded-full bg-[var(--color-accent)] px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider text-white">
              {section.badge[locale]}
            </span>
          )}
        </div>
        <p class="mt-2 text-sm leading-relaxed text-[var(--color-fg)]">
          {section.lead[locale]}
        </p>

        {section.blocks.map((block) =>
          block.type === 'h3' ? (
            <h3 class="mt-6 text-sm font-semibold text-[var(--color-fg)]">
              {block.text[locale]}
            </h3>
          ) : block.type === 'p' ? (
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-fg)]">
              {block.text[locale]}
            </p>
          ) : block.type === 'ul' ? (
            <ul class="mt-3 space-y-2 text-sm leading-relaxed text-[var(--color-fg)]">
              {block.items.map((item) => (
                <li class="flex gap-2">
                  <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-[var(--color-accent)]" aria-hidden="true" />
                  <span>{item[locale]}</span>
                </li>
              ))}
            </ul>
          ) : block.type === 'ol' ? (
            <ol class="mt-3 space-y-3 text-sm leading-relaxed text-[var(--color-fg)]">
              {block.items.map((item, idx) => (
                <li class="flex gap-3">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent-soft)] text-xs font-semibold text-[var(--color-accent)]">
                    {idx + 1}
                  </span>
                  <span class="pt-0.5">{item[locale]}</span>
                </li>
              ))}
            </ol>
          ) : block.type === 'callout' ? (
            <aside
              class:list={[
                'mt-4 rounded-md border px-4 py-3 text-xs leading-relaxed',
                block.tone === 'warn'
                  ? 'border-[var(--color-gold)] bg-[var(--color-gold-soft,rgba(245,210,140,0.15))] text-[var(--color-fg)]'
                  : 'border-[var(--color-line)] bg-[var(--color-accent-soft)] text-[var(--color-fg)]',
              ]}
            >
              {block.text[locale]}
            </aside>
          ) : null,
        )}
      </section>
    ))
  }

  <section class="mt-12 border-t border-[var(--color-line)] pt-8">
    <h2 class="text-lg font-semibold text-[var(--color-fg)] sm:text-xl">
      {locale === 'ko' ? '⑤ 한국에서 자주 쓰는 짧은 표현' : locale === 'en' ? '⑤ A few useful Korean phrases' : '⑤ Ein paar nützliche koreanische Sätze'}
    </h2>
    <p class="mt-2 text-sm leading-relaxed text-[var(--color-fg)]">
      {data.phrasesIntro[locale]}
    </p>

    <div class="mt-4 overflow-hidden rounded-md border border-[var(--color-line)]">
      <table class="w-full text-sm">
        <thead class="bg-[var(--color-accent-soft)] text-xs text-[var(--color-muted)]">
          <tr>
            <th class="px-3 py-2 text-left font-medium">
              {locale === 'ko' ? '한국어' : locale === 'en' ? 'Korean' : 'Koreanisch'}
            </th>
            <th class="px-3 py-2 text-left font-medium">
              {locale === 'ko' ? '발음' : locale === 'en' ? 'Pronunciation' : 'Aussprache'}
            </th>
            <th class="px-3 py-2 text-left font-medium">
              {locale === 'ko' ? '의미' : locale === 'en' ? 'Meaning' : 'Bedeutung'}
            </th>
          </tr>
        </thead>
        <tbody>
          {
            data.phrases.map((p, idx) => (
              <tr class:list={[idx % 2 === 1 && 'bg-white/30']}>
                <td class="px-3 py-2 font-medium text-[var(--color-fg)]">{p.ko}</td>
                <td class="px-3 py-2 text-[var(--color-muted)]">{p.rom}</td>
                <td class="px-3 py-2 text-[var(--color-fg)]">
                  {locale === 'ko' ? p.en : locale === 'en' ? p.en : p.de}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <section class="mt-12 border-t border-[var(--color-line)] pt-8">
    <h2 class="text-lg font-semibold text-[var(--color-fg)] sm:text-xl">
      {data.emergencyHeading[locale]}
    </h2>
    <ul class="mt-3 space-y-2 text-sm leading-relaxed text-[var(--color-fg)]">
      {
        data.emergencyItems.map((item) => (
          <li class="flex gap-2">
            <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-[var(--color-accent)]" aria-hidden="true" />
            <span>{item[locale]}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mt-12 border-t border-[var(--color-line)] pt-8">
    <h2 class="text-lg font-semibold text-[var(--color-fg)] sm:text-xl">
      {data.miscHeading[locale]}
    </h2>
    <ul class="mt-3 space-y-2 text-sm leading-relaxed text-[var(--color-fg)]">
      {
        data.miscItems.map((item) => (
          <li class="flex gap-2">
            <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-[var(--color-accent)]" aria-hidden="true" />
            <span>{item[locale]}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <div class="mt-16 text-center">
    <a
      href={homeHref}
      class="inline-block rounded-md border border-[var(--color-line)] bg-white/60 px-5 py-3 text-sm text-[var(--color-fg)] hover:bg-[var(--color-accent-soft)]"
    >
      {data.outroBack[locale]}
    </a>
  </div>
</article>
