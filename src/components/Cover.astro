---
import { t, tField, withBase, type Locale } from '@lib/i18n';
import venue from '@config/venue.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const groomName = t('cover.groomName', locale);
const brideName = t('cover.brideName', locale);
const sep = t('cover.separator', locale);
const dateLine = t('cover.dateLine', locale);
const timeLine = t('cover.timeLine', locale);
const venueLine = `${tField(venue.name, locale)} · ${tField(venue.hall, locale)}`;
const scrollHint = t('cover.scrollHint', locale);
const eyebrow =
  locale === 'ko' ? '결혼합니다' : locale === 'en' ? 'Getting married' : 'Wir heiraten';
---

<section
  class="relative isolate flex min-h-[100svh] flex-col overflow-hidden bg-[oklch(0.30_0.06_150)] text-white"
  aria-label={`${groomName} ${sep} ${brideName}`}
>
  <!-- Photo area: full width. Right side cropped via object-position so the
       couple is centred; the left edge is kept intact. -->
  <div class="relative flex-1 overflow-hidden">
    <img
      src={withBase('/main/cover-poster.jpg')}
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-[23%_50%]"
      decoding="async"
      fetchpriority="high"
    />
    <!-- Top scrim for name legibility -->
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 top-0 h-2/5 bg-gradient-to-b from-black/55 to-transparent"
    >
    </div>
    <!-- Bottom fade into the green footer -->
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-[oklch(0.30_0.06_150)] to-transparent"
    >
    </div>

    <!-- Names: top center, frosted box -->
    <header class="absolute inset-x-0 top-0 flex justify-center px-6 pt-16 sm:pt-20">
      <div
        class="flex flex-col items-center gap-3 rounded-2xl border border-white/15 bg-[oklch(0.30_0.06_150)]/75 px-8 py-6 text-center shadow-lg backdrop-blur-md sm:gap-4 sm:px-10 sm:py-7"
      >
        <p class="text-[0.7rem] uppercase tracking-[var(--tracking-wedding)] text-white/80 sm:text-xs">
          {eyebrow}
        </p>
        <h1 class="font-serif leading-[1.05] text-[clamp(1.75rem,7.5vw,3.25rem)]">
          <span class="block">{groomName}</span>
          <span
            class="my-1 block text-2xl text-[oklch(0.86_0.13_80)] sm:text-3xl"
            aria-hidden="true">{sep}</span
          >
          <span class="block">{brideName}</span>
        </h1>
      </div>
    </header>
  </div>

  <!-- Schedule + scroll hint: below the photo, on green (as before) -->
  <footer class="relative z-10 flex flex-col items-center gap-4 px-8 pb-10 pt-6 text-center sm:pb-12">
    <div class="space-y-1 text-sm text-white/90 sm:text-base">
      <p>{dateLine}</p>
      <p>{timeLine}</p>
      <p class="pt-2">{venueLine}</p>
    </div>
    <a
      href="#greeting"
      class="group mt-2 flex flex-col items-center gap-2 text-[0.7rem] uppercase tracking-[var(--tracking-wedding)] text-white/70 sm:text-xs"
    >
      {scrollHint}
      <span
        aria-hidden="true"
        class="h-8 w-px bg-gradient-to-b from-white/70 to-transparent transition-transform group-hover:translate-y-1"
      >
      </span>
    </a>
  </footer>
</section>
