---
import { t, type Locale } from '@lib/i18n';
import venue from '@config/venue.json';
import { tField } from '@lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const groomName = t('cover.groomName', locale);
const brideName = t('cover.brideName', locale);
const sep = t('cover.separator', locale);
const dateLine = t('cover.dateLine', locale);
const timeLine = t('cover.timeLine', locale);
const venueLine = `${tField(venue.name, locale)} · ${tField(venue.hall, locale)}`;
const scrollHint = t('cover.scrollHint', locale);
---

<section
  class="relative isolate flex min-h-[100svh] flex-col items-center justify-end overflow-hidden bg-[var(--color-bg)] pb-16 pt-24"
  aria-label={`${groomName} ${sep} ${brideName}`}
>
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-gradient-to-b from-[oklch(0.93_0.04_150)] via-[var(--color-bg)] to-[var(--color-bg)]"
  >
  </div>

  <div class="relative flex flex-1 flex-col items-center justify-center gap-8 px-6 text-center">
    <p class="text-xs uppercase tracking-[var(--tracking-wedding)] text-[var(--color-muted)]">
      {locale === 'ko' ? '결혼합니다' : locale === 'en' ? 'Getting married' : 'Wir heiraten'}
    </p>

    <h1 class="font-serif text-[clamp(2rem,9vw,4rem)] leading-tight text-[var(--color-fg)]">
      <span class="block">{groomName}</span>
      <span class="my-2 block text-3xl text-[var(--color-accent)]" aria-hidden="true">{sep}</span>
      <span class="block">{brideName}</span>
    </h1>

    <div class="space-y-1 text-sm text-[var(--color-muted)] sm:text-base">
      <p>{dateLine}</p>
      <p>{timeLine}</p>
      <p class="pt-2">{venueLine}</p>
    </div>
  </div>

  <a
    href="#greeting"
    class="group relative flex flex-col items-center gap-2 text-xs uppercase tracking-[var(--tracking-wedding)] text-[var(--color-muted)]"
  >
    {scrollHint}
    <span
      aria-hidden="true"
      class="h-10 w-px bg-gradient-to-b from-[var(--color-muted)] to-transparent transition-transform group-hover:translate-y-1"
    >
    </span>
  </a>
</section>
